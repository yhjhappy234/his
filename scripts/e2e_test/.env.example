# HIS Platform E2E Test Configuration
# Copy this file to .env and update with your settings

# Base URL for the HIS Platform API
HIS_BASE_URL=http://localhost:8080

# Test user credentials
HIS_TEST_USER=admin
HIS_TEST_PASSWORD=admin123

# Test configuration
HIS_TEST_TIMEOUT=30000
HIS_TEST_RETRY_COUNT=3
HIS_TEST_RETRY_DELAY=1000

# Report output directory
HIS_REPORT_DIR=../report

# Logging level (DEBUG, INFO, WARNING, ERROR)
HIS_LOG_LEVEL=INFO

# Enable/disable SSL verification (set to 'true' for production)
HIS_VERIFY_SSL=false

# Proxy settings (optional)
# HIS_HTTP_PROXY=http://proxy:8080
# HIS_HTTPS_PROXY=https://proxy:8080